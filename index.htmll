<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador de Senha - Rosa Claro</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #ffeef5 0%, #ffd6e7 50%, #ffccdd 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 25px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(255, 182, 193, 0.3);
            max-width: 500px;
            width: 100%;
            text-align: center;
            border: 2px solid rgba(255, 192, 203, 0.5);
        }

        h1 {
            color: #ff69b4;
            font-size: 2.2em;
            margin-bottom: 10px;
            text-shadow: 0 2px 4px rgba(255, 105, 180, 0.3);
        }

        .subtitle {
            color: #ff91c1;
            margin-bottom: 30px;
            font-size: 1.1em;
        }

        .password-display {
            background: linear-gradient(135deg, #fff0f5, #ffe4e9);
            border: 3px solid #ffb6c1;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 30px;
            font-size: 1.5em;
            font-weight: bold;
            color: #c71585;
            letter-spacing: 2px;
            word-break: break-all;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: all 0.3s ease;
        }

        .password-display:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 25px rgba(255, 105, 180, 0.4);
        }

        .controls {
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-bottom: 30px;
        }

        .slider-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 182, 193, 0.2);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255, 192, 203, 0.5);
        }

        .slider-container label {
            color: #ff69b4;
            font-weight: 600;
            font-size: 1.1em;
        }

        input[type="range"] {
            flex: 1;
            margin: 0 15px;
            height: 8px;
            border-radius: 5px;
            background: #ffb6c1;
            outline: none;
            -webkit-appearance: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            background: #ff69b4;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(255, 105, 180, 0.4);
        }

        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #ff69b4;
            font-weight: 500;
        }

        .checkbox-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: #ff69b4;
            transform: scale(1.2);
        }

        .generate-btn {
            background: linear-gradient(135deg, #ff69b4, #ff1493);
            color: white;
            border: none;
            padding: 18px 40px;
            font-size: 1.3em;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(255, 105, 180, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .generate-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255, 105, 180, 0.6);
        }

        .generate-btn:active {
            transform: translateY(-1px);
        }

        .copy-btn {
            background: linear-gradient(135deg, #98d8c8, #7ee8c9);
            color: #00695c;
            border: none;
            padding: 12px 25px;
            font-size: 1em;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(152, 216, 200, 0.4);
        }

        .copy-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(152, 216, 200, 0.6);
        }

        .strength-indicator
